{
  "manifest_version": 3,
  "name": "Todoist — Pin",
  "version": "1.0.1",
  "description": "Fixe as tarefas na tela para acessá-las com mais facilidade.",
  "author": "Tihh Gonçalves",
  "host_permissions": [
    "https://app.todoist.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://app.todoist.com/*"],
      "js": ["content.js"],
      "css": []
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Todoist — Pin"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
